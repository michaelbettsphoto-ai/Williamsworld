{
  "name": "williamsworld-qa",
  "version": "1.0.0",
  "description": "Playwright QA test suite for Williams World",
  "scripts": {
    "test": "playwright test",
    "test:visual": "playwright test tests/visual-ui.spec.ts",
    "test:functional": "playwright test tests/functional-logic.spec.ts",
    "test:chaos": "playwright test tests/chaos-monkey.spec.ts",
    "test:games": "playwright test tests/games-gameplay.spec.ts",
    "test:battle": "playwright test tests/battle-system.spec.ts",
    "test:progression": "playwright test tests/progression-system.spec.ts",
    "test:audio": "playwright test tests/audio-controls.spec.ts",
    "test:all": "playwright test --reporter=json,html",
    "test:ci": "playwright test --reporter=github,html",
    "report": "ts-node tests/generate-report.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
